# Microsoft OneDrive / Login
# Fill these in .env.local (do NOT commit secrets)
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=common
VITE_MICROSOFT_REDIRECT_URI=

# Azure Computer Vision (Cognitive Services)
# Replace with your endpoint (e.g. https://<your-resource>.cognitiveservices.azure.com)
VITE_AZURE_ENDPOINT=
# Your subscription key (keep secrets out of source control)
VITE_AZURE_KEY=

